
{%- comment -%}
  Home Blog Section
  Layout: cream bg · left intro col (eyebrow, ブログ heading, intro text, View more pill, dog illust)
          right 3-col open card grid (image → date → title → category)
  Open-card style: no white card bg — images float directly on section bg.
  Confirmed against apantry.jp ブログ section screenshot.
{%- endcomment -%}

{%- liquid
  assign source_blog  = blogs[section.settings.blog]
  assign posts_limit  = section.settings.posts_to_show
  assign has_articles = false
  if source_blog != blank and source_blog.articles_count > 0
    assign has_articles = true
  endif

  case section.settings.image_ratio
    when 'landscape'
      assign img_ratio = '4 / 3'
    when 'portrait'
      assign img_ratio = '3 / 4'
    when 'wide'
      assign img_ratio = '16 / 9'
    else
      assign img_ratio = '4 / 3'
  endcase
-%}

{{ 'section-home-blog.css' | asset_url | stylesheet_tag }}

<section
  class="section-home-blog"
  id="home-blog-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    --hb-img-ratio: {{ img_ratio }};
  "
>
  <div class="hb-container">
    <div class="hb-inner">

      {%- comment -%}━━━━━━━━ LEFT: Intro column ━━━━━━━━{%- endcomment -%}
      <div class="hb-label-col">

        {%- comment -%} ✦ Blog eyebrow {%- endcomment -%}
        <p class="hb-eyebrow">
          <span class="hb-eyebrow__icon" aria-hidden="true">✦</span>
          {{- section.settings.eyebrow | default: 'Blog' -}}
        </p>

        {%- comment -%} ブログ heading {%- endcomment -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hb-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- comment -%} Intro paragraph {%- endcomment -%}
        {%- if section.settings.intro_text != blank -%}
          <p class="hb-intro">{{ section.settings.intro_text }}</p>
        {%- endif -%}

        {%- comment -%} View more pill button {%- endcomment -%}
        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="hb-viewall">
            {{- section.settings.cta_label -}}
            <span aria-hidden="true"> ›</span>
          </a>
        {%- endif -%}

        {%- comment -%} Optional decoration (dog illustration) {%- endcomment -%}
        {%- if section.settings.decoration_image != blank -%}
          <div class="hb-decoration">
            {{- section.settings.decoration_image
              | image_url: width: 320
              | image_tag:
                loading: 'lazy',
                widths: '160, 240, 320',
                sizes: '160px',
                alt: ''
            -}}
          </div>
        {%- endif -%}

      </div>

      {%- comment -%}━━━━━━━━ RIGHT: Blog card grid ━━━━━━━━{%- endcomment -%}
      <ul class="hb-grid" role="list">

        {%- if has_articles -%}
          {%- for article in source_blog.articles limit: posts_limit -%}
            <li class="hb-card">
              <a href="{{ article.url }}" class="hb-card__link">

                {%- comment -%} Article image {%- endcomment -%}
                {%- if article.image != blank -%}
                  <div class="hb-card__image-wrap">
                    {{- article.image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 800',
                        sizes: '(max-width: 767px) calc(50vw - 27px), (max-width: 1023px) calc(50vw - 80px), calc((100vw - 344px - 80px) / 3)',
                        class: 'hb-card__image',
                        alt: article.image.alt | default: article.title | escape
                    -}}
                  </div>
                {%- else -%}
                  <div class="hb-card__image-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}

                {%- comment -%} Card body: date → title → category {%- endcomment -%}
                <div class="hb-card__body">

                  {%- if section.settings.show_date -%}
                    <time class="hb-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{- article.published_at | date: '%Y.%m.%d' -}}
                    </time>
                  {%- endif -%}

                  <h3 class="hb-card__title">{{ article.title | escape }}</h3>

                  {%- if section.settings.show_category and article.tags.size > 0 -%}
                    <p class="hb-card__category">{{ article.tags | first }}</p>
                  {%- endif -%}

                </div>

              </a>
            </li>
          {%- endfor -%}

        {%- else -%}

          {%- comment -%} Static placeholders shown in editor when no blog is assigned {%- endcomment -%}
          {%- assign placeholder_count = posts_limit | at_most: 3 -%}

          {%- for i in (1..placeholder_count) -%}
            <li class="hb-card">
              <div class="hb-card__link">
                <div class="hb-card__image-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
                <div class="hb-card__body">
                  {%- if section.settings.show_date -%}
                    <span class="hb-card__date">2026.04.07</span>
                  {%- endif -%}
                  {%- if i == 1 -%}
                    <h3 class="hb-card__title">犬のアレルギーは食べ物が原因？犬が避けるべき食材と対策を解説</h3>
                    {%- if section.settings.show_category -%}<p class="hb-card__category">ライフスタイル</p>{%- endif -%}
                  {%- elsif i == 2 -%}
                    <h3 class="hb-card__title">初めての方におすすめ。パップタブの選び方・使い方完全ガイド</h3>
                    {%- if section.settings.show_category -%}<p class="hb-card__category">商品ガイド</p>{%- endif -%}
                  {%- else -%}
                    <h3 class="hb-card__title">アニーズパントリーはどんなフード専門家による愛犬レビュー</h3>
                    {%- if section.settings.show_category -%}<p class="hb-card__category">Annies Diary</p>{%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            </li>
          {%- endfor -%}

        {%- endif -%}

      </ul>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home blog",
  "class": "home-blog-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Blog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "ブログ"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro paragraph",
      "default": "愛犬の健康といいものを目指すアニーズパントリーのブログ。食事や健康、日々のケアから、お客様の声まで、さまざまな情報を発信しています。"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "decoration_image",
      "label": "Decoration image (e.g. dog illustration)"
    },
    {
      "type": "header",
      "content": "Blog source"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Number of posts",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "landscape", "label": "Landscape (4:3) — default" },
        { "value": "wide",      "label": "Wide (16:9)" },
        { "value": "portrait",  "label": "Portrait (3:4)" }
      ],
      "default": "landscape"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show publish date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show category (first tag)",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F4F1EC"
    }
  ],
  "presets": [
    {
      "name": "Home blog"
    }
  ]
}
{% endschema %}
