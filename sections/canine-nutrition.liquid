
{%- comment -%}
  Canine Nutrition Section
  Layout: cream page bg · full-width rounded image card with overlay
          centered heading + subtext + pill CTA button
  Confirmed against apantry.jp blog/nutrition screenshot.
{%- endcomment -%}

{{ 'section-canine-nutrition.css' | asset_url | stylesheet_tag }}

<section
  class="section-canine-nutrition"
  id="{% if section.settings.section_id != blank %}{{ section.settings.section_id | handleize }}{% else %}canine-nutrition-{{ section.id }}{% endif %}"
  style="
    background-color:    {{ section.settings.bg_color }};
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end:   {{ section.settings.padding_bottom }}px;
    margin-block-end:    {{ section.settings.margin_bottom }}px;
    --cn-heading-color:  {{ section.settings.heading_color }};
    --cn-subtext-color:  {{ section.settings.subtext_color }};
    --cn-btn-bg:         {{ section.settings.button_bg_color }};
    --cn-btn-text:       {{ section.settings.button_text_color }};
    --cn-radius:         {{ section.settings.card_radius }}px;
    --cn-min-height:     {{ section.settings.card_height }}px;
    --cn-min-height-tablet: {{ section.settings.card_height | times: 0.8 | round }}px;
    --cn-min-height-mobile: {{ section.settings.card_height | times: 0.6 | round }}px;
  "
>
  <div class="cn-wrapper">
    <div class="cn-card">

      {%- comment -%} Background image {%- endcomment -%}
      {%- if section.settings.image != blank -%}
        {{- section.settings.image
          | image_url: width: 2400
          | image_tag:
            loading: 'lazy',
            fetchpriority: 'auto',
            widths: '800, 1200, 1600, 2400',
            sizes: '(max-width: 767px) calc(100vw - 32px), (max-width: 1023px) calc(100vw - 40px), calc(100vw - 48px)',
            class: 'cn-image',
            alt: section.settings.image.alt | default: section.settings.heading | escape
        -}}
      {%- else -%}
        <div class="cn-image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
      {%- endif -%}

      {%- comment -%} Overlay {%- endcomment -%}
      <div
        class="cn-overlay"
        style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
        aria-hidden="true"
      ></div>

      {%- comment -%} Content {%- endcomment -%}
      <div class="cn-content cn-content--{{ section.settings.text_alignment }}">

        {%- if section.settings.heading != blank -%}
          <h2 class="cn-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <p class="cn-subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
          <a href="{{ section.settings.button_url }}" class="cn-button">
            {{- section.settings.button_label -}}
          </a>
        {%- endif -%}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Canine nutrition",
  "class": "canine-nutrition-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section ID"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Used for tab navigation scroll targeting. No spaces or # (e.g. canine-nutrition-section)."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height (desktop)",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "生食ドッグフードと犬の栄養学を学ぶ"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "海外のペット栄養学やフレッシュフードの考え方など、愛犬の健康に役立つ情報をブログで発信しています。"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "ブログを読む"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Page background color",
      "default": "#F5F0E4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#2C2420"
    }
  ],
  "presets": [
    {
      "name": "Canine nutrition"
    }
  ]
}
{% endschema %}
