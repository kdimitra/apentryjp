
{% assign blends = product.metafields.custom.annies_natural_blend.value %}

{% if blends != blank %}
<section class="anb-section" id="annies-natural-blend">
  <div class="anb-wrapper">

    <!-- Header -->
    <div class="anb-header js-anb-header">
      <p class="anb-eyebrow">
        <span class="anb-eyebrow__icon">🐾</span>
        {{ section.settings.eyebrow_text }}
        <span class="anb-eyebrow__icon">🐾</span>
      </p>
      <h2 class="anb-heading">{{ section.settings.section_heading }}</h2>
    </div>

    <!-- Grid -->
    <div class="anb-grid">
      {% for blend in blends %}
        <div class="anb-card js-anb-card" style="--ci: {{ forloop.index0 }}">

          <!-- Image -->
          <div class="anb-card__img-wrap">
            {% if blend.image != blank %}
              <img
                class="anb-card__img"
                src="{{ blend.image | image_url: width: 160 }}"
                alt="{{ blend.title | escape }}"
                loading="lazy"
                width="80"
                height="80"
              />
            {% else %}
              <div class="anb-card__img-placeholder">
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="16" fill="#e8e0d0"/>
                  <path d="M14 26c1-4 11-4 12 0" stroke="#bbb" stroke-width="1.5" stroke-linecap="round"/>
                  <circle cx="16" cy="18" r="2" fill="#bbb"/>
                  <circle cx="24" cy="18" r="2" fill="#bbb"/>
                </svg>
              </div>
            {% endif %}
          </div>

          <!-- Text -->
          <div class="anb-card__text">
            {% if blend.title != blank %}
              <h3 class="anb-card__title">{{ blend.title }}</h3>
            {% endif %}
            {% if blend.short_description != blank %}
              <p class="anb-card__desc">{{ blend.short_description }}</p>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

<style>
/* ============================================================
   SECTION
============================================================ */
.anb-section {
  background: {{ section.settings.bg_color }};
  padding: 72px 24px 88px;
  font-family: 'Noto Sans JP', 'Hiragino Kaku Gothic Pro', 'Yu Gothic', sans-serif;
}

.anb-wrapper {
  max-width: 1100px;
  margin: 0 auto;
}

/* ============================================================
   HEADER
============================================================ */
.anb-header {
  text-align: center;
  margin-bottom: 52px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.anb-header.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.anb-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #555;
  letter-spacing: 0.1em;
  margin-bottom: 16px;
}
.anb-eyebrow__icon {
  font-size: 14px;
  line-height: 1;
}

.anb-heading {
  font-size: clamp(24px, 3.5vw, 38px);
  font-weight: 700;
  color: #2a2a2a;
  letter-spacing: 0.04em;
  margin: 0;
  line-height: 1.4;
}

/* ============================================================
   GRID — 3 columns fixed per row
============================================================ */
.anb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ============================================================
   CARD
============================================================ */
.anb-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 28px 24px 28px;
  display: flex;
  align-items: flex-start;
  gap: 18px;
  box-shadow:
    0 2px 8px rgba(0,0,0,0.05),
    0 0 0 1px rgba(0,0,0,0.03);
  transition:
    transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.4s ease;

  /* Scroll animation */
  opacity: 0;
  transform: translateY(32px);
  transition:
    opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1) calc(var(--ci, 0) % 3 * 100ms),
    transform 0.65s cubic-bezier(0.22, 1, 0.36, 1) calc(var(--ci, 0) % 3 * 100ms),
    box-shadow 0.4s ease;
}
.anb-card.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.anb-card:hover {
  transform: translateY(-5px);
  box-shadow:
    0 10px 28px rgba(0,0,0,0.09),
    0 0 0 1px rgba(0,0,0,0.04);
}

/* ── Image wrap ── */
.anb-card__img-wrap {
  flex-shrink: 0;
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.anb-card__img {
  width: 64px;
  height: 64px;
  object-fit: contain;
  display: block;
  transition: transform 0.4s ease;
}
.anb-card:hover .anb-card__img {
  transform: scale(1.08) rotate(-3deg);
}
.anb-card__img-placeholder {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.anb-card__img-placeholder svg {
  width: 100%;
  height: 100%;
}

/* ── Text ── */
.anb-card__text {
  flex: 1;
  min-width: 0;
}

.anb-card__title {
  font-size: 16px;
  font-weight: 700;
  color: #2a2a2a;
  margin: 0 0 10px;
  line-height: 1.4;
}

.anb-card__desc {
  font-size: 13px;
  color: #666;
  line-height: 1.85;
  margin: 0;
}

/* ============================================================
   TABLET — 2 columns  ≤ 860px
============================================================ */
@media (max-width: 860px) {
  .anb-section {
    padding: 56px 20px 72px;
  }
  .anb-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .anb-card {
    padding: 24px 20px;
  }
}

/* ============================================================
   MOBILE — 1 column  ≤ 520px
============================================================ */
@media (max-width: 520px) {
  .anb-section {
    padding: 44px 14px 60px;
  }
  .anb-header {
    margin-bottom: 36px;
  }
  .anb-grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .anb-card {
    padding: 20px 18px;
    gap: 14px;
  }
  .anb-card__img,
  .anb-card__img-wrap {
    width: 52px;
    height: 52px;
  }
  .anb-card__title {
    font-size: 15px;
  }
  .anb-card__desc {
    font-size: 13px;
  }
}
</style>

<script>
(function () {
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.10, rootMargin: '0px 0px -20px 0px' });

  var header = document.querySelector('.anb-header');
  if (header) io.observe(header);

  document.querySelectorAll('.anb-card').forEach(function (el) {
    io.observe(el);
  });
})();
</script>

{% schema %}
{
  "name": "Annie's Natural Blend",
  "tag": "section",
  "class": "section-annies-natural-blend",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Label",
      "default": "Annie's Natural Blend"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "栄養豊富な原材料入りタブ"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f0e8"
    }
  ],
  "presets": [
    {
      "name": "Annie's Natural Blend"
    }
  ]
}
{% endschema %}
