
{%- comment -%}
  Annie's Natural Blend
  Layout: cream bg · centered eyebrow + heading · 3-col card grid
  Cards are managed as blocks in the theme editor.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<section class="anb-section" id="{% if section.settings.section_id != blank %}{{ section.settings.section_id | handleize }}{% else %}annies-natural-blend-{{ section.id }}{% endif %}">
  <div class="anb-wrapper">

    {%- comment -%} Header {%- endcomment -%}
    <div class="anb-header js-anb-header">

      {%- if section.settings.eyebrow_text != blank -%}
        <p class="anb-eyebrow">
          <span class="anb-eyebrow__icon" aria-hidden="true">
            {%- if section.settings.eyebrow_icon_left != blank -%}
              {{- section.settings.eyebrow_icon_left | image_url: width: 36 | image_tag: loading: 'lazy', alt: '' -}}
            {%- else -%}
              <svg viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
                <ellipse cx="16" cy="22.5" rx="6.5" ry="5.5"/>
                <ellipse cx="7.5" cy="15" rx="3" ry="3.8" transform="rotate(-10 7.5 15)"/>
                <ellipse cx="24.5" cy="15" rx="3" ry="3.8" transform="rotate(10 24.5 15)"/>
                <circle cx="12" cy="10" r="3"/>
                <circle cx="20" cy="10" r="3"/>
              </svg>
            {%- endif -%}
          </span>
          {{- section.settings.eyebrow_text -}}
          <span class="anb-eyebrow__icon" aria-hidden="true">
            {%- if section.settings.eyebrow_icon_right != blank -%}
              {{- section.settings.eyebrow_icon_right | image_url: width: 36 | image_tag: loading: 'lazy', alt: '' -}}
            {%- else -%}
              <svg viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
                <ellipse cx="16" cy="22.5" rx="6.5" ry="5.5"/>
                <ellipse cx="7.5" cy="15" rx="3" ry="3.8" transform="rotate(-10 7.5 15)"/>
                <ellipse cx="24.5" cy="15" rx="3" ry="3.8" transform="rotate(10 24.5 15)"/>
                <circle cx="12" cy="10" r="3"/>
                <circle cx="20" cy="10" r="3"/>
              </svg>
            {%- endif -%}
          </span>
        </p>
      {%- endif -%}

      {%- if section.settings.section_heading != blank -%}
        <h2 class="anb-heading">{{ section.settings.section_heading }}</h2>
      {%- endif -%}

    </div>

    {%- comment -%} Card grid {%- endcomment -%}
    <div class="anb-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'blend_card' -%}
          <div class="anb-card js-anb-card" style="--ci: {{ forloop.index0 }}" {{ block.shopify_attributes }}>

            {%- comment -%} Image {%- endcomment -%}
            <div class="anb-card__img-wrap">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image
                  | image_url: width: 160
                  | image_tag:
                    loading: 'lazy',
                    widths: '80, 120, 160',
                    sizes: '64px',
                    class: 'anb-card__img',
                    alt: block.settings.title | escape
                -}}
              {%- else -%}
                <div class="anb-card__img-placeholder">
                  <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="20" cy="20" r="16" fill="#e8e0d0"/>
                    <path d="M14 26c1-4 11-4 12 0" stroke="#bbb" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="16" cy="18" r="2" fill="#bbb"/>
                    <circle cx="24" cy="18" r="2" fill="#bbb"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Text {%- endcomment -%}
            <div class="anb-card__text">
              {%- if block.settings.title != blank -%}
                <h3 class="anb-card__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="anb-card__desc">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

<style>
/* ============================================================
   SECTION
============================================================ */
.anb-section {
  background: {{ section.settings.bg_color }};
  padding: 72px 24px 88px;
  font-family: 'gt-ultra', sans-serif;
}

.anb-wrapper {
  max-width: 1100px;
  margin: 0 auto;
}

/* ============================================================
   HEADER
============================================================ */
.anb-header {
  text-align: center;
  margin-bottom: 52px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.anb-header.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.anb-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #555;
  letter-spacing: 0.1em;
  margin-bottom: 16px;
}

.anb-eyebrow__icon {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.anb-eyebrow__icon svg,
.anb-eyebrow__icon img {
  display: block;
  width: 18px !important;
  height: 18px !important;
  object-fit: contain;
  color: #555;
}

.anb-heading {
  font-size: clamp(24px, 3.5vw, 38px);
  font-weight: 700;
  color: #2a2a2a;
  letter-spacing: 0.04em;
  margin: 0;
  line-height: 1.4;
}

/* ============================================================
   GRID — 3 columns fixed per row
============================================================ */
.anb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ============================================================
   CARD
============================================================ */
.anb-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 28px 24px;
  display: flex;
  align-items: flex-start;
  gap: 18px;
  box-shadow:
    0 2px 8px rgba(0,0,0,0.05),
    0 0 0 1px rgba(0,0,0,0.03);
  opacity: 0;
  transform: translateY(32px);
  transition:
    opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1) calc(var(--ci, 0) % 3 * 100ms),
    transform 0.65s cubic-bezier(0.22, 1, 0.36, 1) calc(var(--ci, 0) % 3 * 100ms),
    box-shadow 0.4s ease;
}
.anb-card.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.anb-card:hover {
  transform: translateY(-5px);
  box-shadow:
    0 10px 28px rgba(0,0,0,0.09),
    0 0 0 1px rgba(0,0,0,0.04);
}

/* ── Image wrap ── */
.anb-card__img-wrap {
  flex-shrink: 0;
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.anb-card__img {
  width: 64px !important;
  height: 64px !important;
  object-fit: contain;
  display: block;
  transition: transform 0.4s ease;
}
.anb-card:hover .anb-card__img {
  transform: scale(1.08) rotate(-3deg);
}

.anb-card__img-placeholder {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.anb-card__img-placeholder svg {
  width: 100%;
  height: 100%;
}

/* ── Text ── */
.anb-card__text {
  flex: 1;
  min-width: 0;
}

.anb-card__title {
  font-size: 16px;
  font-weight: 700;
  color: #2a2a2a;
  margin: 0 0 10px;
  line-height: 1.4;
}

.anb-card__desc {
  font-size: 13px;
  color: #666;
  line-height: 1.85;
  margin: 0;
}

.anb-card__desc p {
  margin: 0 0 0.5em;
  font-size: inherit;
  color: inherit;
  line-height: inherit;
}
.anb-card__desc p:last-child { margin-bottom: 0; }

/* ============================================================
   TABLET — 2 columns  ≤ 860px
============================================================ */
@media (max-width: 860px) {
  .anb-section { padding: 56px 20px 72px; }
  .anb-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .anb-card { padding: 24px 20px; }
}

/* ============================================================
   MOBILE — 1 column  ≤ 520px
============================================================ */
@media (max-width: 520px) {
  .anb-section { padding: 44px 14px 60px; }
  .anb-header { margin-bottom: 36px; }
  .anb-grid { grid-template-columns: 1fr; gap: 14px; }
  .anb-card { padding: 20px 18px; gap: 14px; }
  .anb-card__img,
  .anb-card__img-wrap { width: 52px; height: 52px; }
  .anb-card__title { font-size: 15px; }
}
</style>

<script>
(function () {
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.10, rootMargin: '0px 0px -20px 0px' });

  var header = document.querySelector('.anb-header');
  if (header) io.observe(header);
  document.querySelectorAll('.anb-card').forEach(function (el) { io.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Annie's Natural Blend",
  "tag": "section",
  "class": "section-annies-natural-blend",
  "settings": [
    {
      "type": "header",
      "content": "Section ID"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Used for scroll targeting. No spaces or # (e.g. natural-blend-section)."
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow label",
      "default": "Annie's Natural Blend"
    },
    {
      "type": "image_picker",
      "id": "eyebrow_icon_left",
      "label": "Left paw icon (SVG/PNG)",
      "info": "Leave blank to use the built-in default paw SVG."
    },
    {
      "type": "image_picker",
      "id": "eyebrow_icon_right",
      "label": "Right paw icon (SVG/PNG)",
      "info": "Leave blank to use the built-in default paw SVG."
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "栄養豊富な原材料入りタブ"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f5f0e8"
    }
  ],
  "blocks": [
    {
      "type": "blend_card",
      "name": "Blend card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon / image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "新鮮なお肉"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>厳選した新鮮な素材だけを使用しています。</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Annie's Natural Blend",
      "blocks": [
        {
          "type": "blend_card",
          "settings": {
            "title": "新鮮なお肉",
            "description": "<p>厳選した新鮮な素材だけを使用しています。</p>"
          }
        },
        {
          "type": "blend_card",
          "settings": {
            "title": "国産野菜",
            "description": "<p>国内産の旬の野菜を丁寧に使っています。</p>"
          }
        },
        {
          "type": "blend_card",
          "settings": {
            "title": "無添加製法",
            "description": "<p>香料・着色料・保存料は一切不使用です。</p>"
          }
        }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
