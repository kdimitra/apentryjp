
{%- doc -%}
  Custom Annie's Pantry Footer
  Matches the design on apantry.jp — teal background, food list grid,
  nav columns, social links, and an optional decoration image.
{%- enddoc -%}

{%- liquid
  assign food_items    = section.blocks | where: 'type', 'food_item'
  assign about_links   = section.blocks | where: 'type', 'about_link'
  assign service_links = section.blocks | where: 'type', 'service_link'
-%}

<div
  class="ap-footer"
  style="
    --ap-bg:         {{ section.settings.background_color }};
    --ap-card-bg:    {{ section.settings.card_background_color }};
    --ap-text:       {{ section.settings.text_color }};
    --ap-pt:         {{ section.settings.padding_top }}px;
    --ap-pb:         {{ section.settings.padding_bottom }}px;
  "
>
  <div class="ap-footer__inner section--page-width">

    {%- comment -%}━━━━━━━━━━━━━ TOP: Logo + Food list ━━━━━━━━━━━━━{%- endcomment -%}
    <div class="ap-footer__top">

      {%- comment -%} LEFT — Brand {%- endcomment -%}
      <div class="ap-footer__brand">
        {%- if section.settings.logo -%}
          <img
            src="{{ section.settings.logo | image_url: width: 220 }}"
            alt="{{ shop.name | escape }}"
            class="ap-footer__logo"
            width="{{ section.settings.logo.width | at_most: 220 }}"
            height="auto"
            loading="lazy"
          >
        {%- else -%}
          <span class="ap-footer__shop-name">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="ap-footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT — Food list {%- endcomment -%}
      <div class="ap-footer__food-section">

        <div class="ap-footer__food-header">
          <h2 class="ap-footer__food-title">
            {{- section.settings.food_list_heading | default: 'Food list' -}}
          </h2>
          {%- if section.settings.view_all_url != blank -%}
            <a href="{{ section.settings.view_all_url }}" class="ap-footer__view-all">
              {{- section.settings.view_all_text | default: 'View all' -}}
              <span aria-hidden="true">&rsaquo;</span>
            </a>
          {%- endif -%}
        </div>

        {%- if food_items.size > 0 -%}
          <div class="ap-footer__food-grid">
            {%- for block in food_items -%}
              <a
                href="{{ block.settings.url | default: '#' }}"
                class="ap-footer__food-card"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 100 }}"
                    alt="{{ block.settings.title | escape }}"
                    class="ap-footer__food-img"
                    width="60"
                    height="60"
                    loading="lazy"
                  >
                {%- endif -%}
                <span class="ap-footer__food-name">{{ block.settings.title }}</span>
                <span class="ap-footer__card-arrow" aria-hidden="true">&rsaquo;</span>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    </div>

    {%- comment -%}━━━━━━━━━━━━━ DIVIDER ━━━━━━━━━━━━━{%- endcomment -%}
    <hr class="ap-footer__divider">

    {%- comment -%}━━━━━━━━━━━━━ BOTTOM: Nav + Decoration ━━━━━━━━━━━━━{%- endcomment -%}
    <div class="ap-footer__bottom">

      {%- comment -%} About Us {%- endcomment -%}
      <div class="ap-footer__nav-col">
        <h3 class="ap-footer__nav-heading">
          {{- section.settings.about_heading | default: 'About us' -}}
        </h3>
        {%- if about_links.size > 0 -%}
          <ul class="ap-footer__nav-list">
            {%- for block in about_links -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url | default: '#' }}" class="ap-footer__nav-link">
                  {{- block.settings.label -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} Customer Service {%- endcomment -%}
      <div class="ap-footer__nav-col">
        <h3 class="ap-footer__nav-heading">
          {{- section.settings.service_heading | default: 'Customer service' -}}
        </h3>
        {%- if service_links.size > 0 -%}
          <ul class="ap-footer__nav-list">
            {%- for block in service_links -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url | default: '#' }}" class="ap-footer__nav-link">
                  {{- block.settings.label -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} Follow Us {%- endcomment -%}
      <div class="ap-footer__nav-col">
        <h3 class="ap-footer__nav-heading">
          {{- section.settings.social_heading | default: 'Follow us' -}}
        </h3>
        <ul class="ap-footer__nav-list ap-footer__social-list">
          {%- if section.settings.instagram_url != blank -%}
            <li>
              <a
                href="{{ section.settings.instagram_url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="ap-footer__social-link"
              >
                <span class="ap-footer__social-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                  </svg>
                </span>
                Instagram
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <li>
              <a
                href="{{ section.settings.tiktok_url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="ap-footer__social-link"
              >
                <span class="ap-footer__social-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V9.06a8.19 8.19 0 0 0 4.79 1.53V7.15a4.85 4.85 0 0 1-1.02-.46z"/>
                  </svg>
                </span>
                TikTok
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.line_url != blank -%}
            <li>
              <a
                href="{{ section.settings.line_url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="ap-footer__social-link"
              >
                <span class="ap-footer__social-icon ap-footer__social-icon--line" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                    <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
                  </svg>
                </span>
                LINE
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Decoration image (bottom-right) {%- endcomment -%}
      {%- if section.settings.footer_image -%}
        <div class="ap-footer__decoration" aria-hidden="true">
          <img
            src="{{ section.settings.footer_image | image_url: width: 320 }}"
            alt=""
            width="{{ section.settings.footer_image.width | at_most: 320 }}"
            loading="lazy"
            role="presentation"
          >
        </div>
      {%- endif -%}

    </div>{%- comment -%} /.ap-footer__bottom {%- endcomment -%}

    {%- comment -%}━━━━━━━━━━━━━ COPYRIGHT ━━━━━━━━━━━━━{%- endcomment -%}
    {%- if section.settings.show_copyright -%}
      <div class="ap-footer__copyright">
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>{%- comment -%} /.ap-footer__inner {%- endcomment -%}
</div>{%- comment -%} /.ap-footer {%- endcomment -%}

{% stylesheet %}
/* ============================================================
   AP FOOTER — Custom Annie's Pantry footer
   ============================================================ */

.ap-footer {
  background-color: var(--ap-bg, #6DC8D8);
  color: var(--ap-text, #3d2b1a);
  padding-top: var(--ap-pt, 48px);
  padding-bottom: var(--ap-pb, 64px);
  position: relative;
  overflow: hidden;
  /* Rounded top-left and top-right corners matching the screenshot */
  border-radius: 150px 150px 0 0;
}

.ap-footer__inner {
  position: relative;
  z-index: 1;
  /* Col-md-2 equivalent spacing: ~8% on each side, max 140px */
  max-width: 1440px;
  margin-inline: auto;
  padding-inline: clamp(24px, 8%, 140px);
}

/* ── TOP SECTION ─────────────────────────────────────── */
.ap-footer__top {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  margin-bottom: 48px;
}

@media screen and (min-width: 750px) {
  .ap-footer__top {
    grid-template-columns: minmax(160px, 220px) 1fr;
    gap: 56px;
    align-items: flex-start;
  }
}

/* Brand / Logo */
.ap-footer__brand {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10px;
}

.ap-footer__logo {
  max-width: 180px;
  height: auto;
  display: block;
}

.ap-footer__shop-name {
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--ap-text, #3d2b1a);
  line-height: 1.2;
}

.ap-footer__tagline {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: var(--ap-text, #3d2b1a);
  margin: 0;
}

/* Food section */
.ap-footer__food-section {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.ap-footer__food-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.ap-footer__food-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--ap-text, #3d2b1a);
  margin: 0;
}

/* "View all ›" button */
.ap-footer__view-all {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 7px 20px;
  background-color: #ffffff;
  border: 1.5px solid rgba(61, 43, 26, 0.35);
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--ap-text, #3d2b1a);
  text-decoration: none;
  white-space: nowrap;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.ap-footer__view-all:hover {
  background-color: var(--ap-text, #3d2b1a);
  color: #ffffff;
}

/* Food grid — 2 columns */
.ap-footer__food-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

/* Individual food card */
.ap-footer__food-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background-color: var(--ap-card-bg, #f0e8d0);
  border-radius: 14px;
  text-decoration: none;
  color: var(--ap-text, #3d2b1a);
  transition: opacity 0.18s ease;
}

.ap-footer__food-card:hover {
  opacity: 0.82;
}

.ap-footer__food-img {
  width: 56px;
  height: 56px;
  object-fit: contain;
  flex-shrink: 0;
  border-radius: 6px;
}

.ap-footer__food-name {
  flex: 1;
  font-size: 0.875rem;
  font-weight: 500;
  line-height: 1.35;
}

.ap-footer__card-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: 1.5px solid rgba(61, 43, 26, 0.28);
  border-radius: 50%;
  font-size: 1.1rem;
  flex-shrink: 0;
  color: var(--ap-text, #3d2b1a);
}

/* ── DIVIDER ─────────────────────────────────────────── */
.ap-footer__divider {
  border: none;
  border-top: 1px solid rgba(61, 43, 26, 0.18);
  margin: 0 0 36px;
}

/* ── BOTTOM SECTION ─────────────────────────────────── */
.ap-footer__bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px 20px;
  position: relative;
}

@media screen and (min-width: 750px) {
  .ap-footer__bottom {
    grid-template-columns: repeat(3, auto);
    justify-content: flex-start;
    gap: 0 80px;
  }
}

/* Nav column */
.ap-footer__nav-col {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.ap-footer__nav-heading {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--ap-text, #3d2b1a);
  margin: 0;
  /* Sentence case — first letter capital, rest lower */
  text-transform: none;
}

.ap-footer__nav-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 9px;
}

.ap-footer__nav-link {
  font-size: 0.875rem;
  color: var(--ap-text, #3d2b1a);
  text-decoration: none;
  line-height: 1.4;
  transition: color 0.15s ease;
}

/* Hover: text links turn brand brown, no underline */
.ap-footer__nav-link:hover {
  color: #5e3826;
  text-decoration: none;
}

/* Social links */
.ap-footer__social-link {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: var(--ap-text, #3d2b1a);
  text-decoration: none;
  line-height: 1.4;
  transition: opacity 0.15s ease;
}

/* Social hover: no color change — only subtle opacity, icon color preserved */
.ap-footer__social-link:hover {
  color: var(--ap-text, #3d2b1a);
  text-decoration: none;
  opacity: 0.8;
}

.ap-footer__social-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 20px;
  height: 20px;
}

.ap-footer__social-icon--line {
  color: #06c755;
}

/* ── DECORATION IMAGE ────────────────────────────────── */
.ap-footer__decoration {
  display: none;
  position: absolute;
  bottom: calc(var(--ap-pb, 64px) * -1);
  right: 0;
  width: 220px;
  pointer-events: none;
  z-index: 0;
}

.ap-footer__decoration img {
  width: 100%;
  height: auto;
  display: block;
}

@media screen and (min-width: 750px) {
  .ap-footer__decoration {
    display: block;
    width: 240px;
  }
}

@media screen and (min-width: 990px) {
  .ap-footer__decoration {
    width: 280px;
  }
}

/* ── COPYRIGHT ───────────────────────────────────────── */
.ap-footer__copyright {
  margin-top: 36px;
  font-size: 1rem;
  color: rgba(61, 43, 26, 0.65);
}

.ap-footer__copyright a {
  color: inherit;
  text-decoration: underline;
}
footer{
  background: #faf7e6;
}
{% endstylesheet %}

{% schema %}
