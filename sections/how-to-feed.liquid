
{%- comment -%}
  How To Feed Section
  Layout: sky-blue bg · dog illust top-left · centered eyebrow + heading
          3 step cards · check/dosage card · food amount simulator card
  Blocks: step_card (image, step label, heading, body)
          dosage_row  (label, value)
{%- endcomment -%}

{{ 'section-how-to-feed.css' | asset_url | stylesheet_tag }}

<section
  class="section-how-to-feed"
  id="{% if section.settings.section_id != blank %}{{ section.settings.section_id | handleize }}{% else %}how-to-feed-{{ section.id }}{% endif %}"
  style="
    background-color:       {{ section.settings.bg_color }};
    --htf-card-bg:          {{ section.settings.card_bg_color }};
    --htf-cell-bg:          {{ section.settings.cell_bg_color }};
    --htf-step-badge-bg:    {{ section.settings.step_badge_bg_color }};
    --htf-step-badge-text:  {{ section.settings.step_badge_text_color }};
    --htf-dark-badge-bg:    {{ section.settings.dark_badge_bg_color }};
    --htf-heading-color:    {{ section.settings.heading_color }};
    --htf-body-color:       {{ section.settings.body_color }};
    --htf-eyebrow-color:    {{ section.settings.eyebrow_color }};
    --htf-eyebrow-icon:     {{ section.settings.eyebrow_icon_color }};
    --htf-button-bg:        {{ section.settings.button_bg_color }};
    --htf-dog-width:        {{ section.settings.dog_illustration_width }}px;
  "
>
  <div class="htf-container">

    {%- comment -%}━━━━━━━━ HEADER ━━━━━━━━{%- endcomment -%}
    <div class="htf-header">

      {%- comment -%} Dog illustration — top-left {%- endcomment -%}
      {%- if section.settings.dog_illustration != blank -%}
        {%- assign dog_sizes = section.settings.dog_illustration_width | append: 'px' -%}
        <div class="htf-dog-wrap">
          {{- section.settings.dog_illustration
            | image_url: width: 440
            | image_tag:
              loading: 'eager',
              widths: '220, 330, 440',
              sizes: dog_sizes,
              alt: ''
          -}}
        </div>
      {%- endif -%}

      <div class="htf-header-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="htf-eyebrow">
            {%- if section.settings.eyebrow_icon_left != blank -%}
              <span class="htf-eyebrow__icon" aria-hidden="true" style="color:{{ section.settings.eyebrow_icon_color }};">
                {{- section.settings.eyebrow_icon_left -}}
              </span>
            {%- endif -%}
            {{- section.settings.eyebrow -}}
            {%- if section.settings.eyebrow_icon_right != blank -%}
              <span class="htf-eyebrow__icon" aria-hidden="true" style="color:{{ section.settings.eyebrow_icon_color }};">
                {{- section.settings.eyebrow_icon_right -}}
              </span>
            {%- endif -%}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="htf-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}━━━━━━━━ STEP CARDS ━━━━━━━━{%- endcomment -%}
    {%- assign step_blocks = section.blocks | where: 'type', 'step_card' -%}
    {%- if step_blocks.size > 0 -%}
      <div class="htf-steps">
        {%- for block in step_blocks -%}
          <div class="htf-step-card" {{ block.shopify_attributes }}>

            <div class="htf-step-image-wrap">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image
                  | image_url: width: 300
                  | image_tag:
                    loading: 'lazy',
                    widths: '150, 220, 300',
                    sizes: '130px',
                    alt: block.settings.image.alt | default: block.settings.heading | escape
                -}}
              {%- else -%}
                <div class="htf-step-image-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>

            <div class="htf-step-card-text">
              {%- if block.settings.step_label != blank -%}
                <span class="htf-step-badge">{{ block.settings.step_label }}</span>
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h3 class="htf-step-title">{{ block.settings.heading }}</h3>
              {%- endif -%}

              {%- if block.settings.body != blank -%}
                <p class="htf-step-body">{{ block.settings.body }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%}━━━━━━━━ CHECK / DOSAGE CARD ━━━━━━━━{%- endcomment -%}
    {%- assign dosage_blocks = section.blocks | where: 'type', 'dosage_row' -%}
    {%- if section.settings.check_heading != blank or dosage_blocks.size > 0 -%}
      <div class="htf-check">

        <div class="htf-check-left">
          {%- if section.settings.check_badge != blank -%}
            <span class="htf-dark-badge">{{ section.settings.check_badge }}</span>
          {%- endif -%}
          {%- if section.settings.check_heading != blank -%}
            <h3 class="htf-check-heading">{{ section.settings.check_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.check_desc != blank -%}
            <p class="htf-check-desc">{{ section.settings.check_desc }}</p>
          {%- endif -%}
        </div>

        <div class="htf-check-right">
          {%- if dosage_blocks.size > 0 -%}
            <div class="htf-dosage-table">
              {%- for block in dosage_blocks -%}
                <div class="htf-dosage-row" {{ block.shopify_attributes }}>
                  <div class="htf-dosage-cell">
                    <span class="htf-dosage-cell__icon" aria-hidden="true">🐾</span>
                    {{ block.settings.label }}
                  </div>
                  <div class="htf-dosage-cell">{{ block.settings.value }}</div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

      </div>
    {%- endif -%}

    {%- comment -%}━━━━━━━━ SIMULATOR CARD ━━━━━━━━{%- endcomment -%}
    {%- if section.settings.show_simulator -%}
      <div class="htf-simulator">

        <div class="htf-sim-left">
          {%- if section.settings.sim_badge != blank -%}
            <span class="htf-dark-badge">{{ section.settings.sim_badge }}</span>
          {%- endif -%}
          {%- if section.settings.sim_heading != blank -%}
            <h3 class="htf-sim-heading">{{ section.settings.sim_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.sim_desc != blank -%}
            <p class="htf-sim-desc">{{ section.settings.sim_desc }}</p>
          {%- endif -%}
        </div>

        <div class="htf-sim-right">
          <form class="htf-sim-form" novalidate>

            <div class="htf-sim-fields">
              <div class="htf-sim-field">
                <label class="htf-sim-label" for="htf-weight-{{ section.id }}">
                  {{ section.settings.sim_weight_label | default: '愛犬の体重' }}
                </label>
                <div style="display:flex;align-items:center;gap:6px;">
                  <input
                    id="htf-weight-{{ section.id }}"
                    class="htf-sim-input htf-sim-weight"
                    type="number"
                    min="0.1"
                    max="100"
                    step="0.1"
                    placeholder="00"
                    aria-label="{{ section.settings.sim_weight_label | default: '愛犬の体重' }}"
                  >
                  <span style="font-family:'DM Sans',sans-serif;font-size:13px;color:var(--htf-body-color);white-space:nowrap;">kg</span>
                </div>
              </div>

              <div class="htf-sim-field">
                <label class="htf-sim-label" for="htf-stage-{{ section.id }}">
                  {{ section.settings.sim_stage_label | default: '愛犬のライフステージ' }}
                </label>
                <div class="htf-sim-select-wrap">
                  <select
                    id="htf-stage-{{ section.id }}"
                    class="htf-sim-select htf-sim-stage"
                    aria-label="{{ section.settings.sim_stage_label | default: '愛犬のライフステージ' }}"
                  >
                    <option value="puppy">子犬</option>
                    <option value="active">活発な成犬</option>
                    <option value="adult" selected>成犬</option>
                    <option value="senior">シニア犬</option>
                    <option value="pregnant">妊娠中</option>
                    <option value="nursing">妊娠後期・授乳中</option>
                  </select>
                </div>
              </div>
            </div>

            <button type="button" class="htf-sim-button">
              {{ section.settings.sim_button_label | default: 'ご飯の量を確認する' }}
            </button>

            <p class="htf-sim-result" aria-live="polite"></p>

          </form>
        </div>

      </div>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'section-how-to-feed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "How to feed",
  "class": "how-to-feed-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section ID"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Used for tab navigation targeting. No spaces or # needed (e.g. feeding-guide-section)."
    },
    {
      "type": "header",
      "content": "Dog Illustration"
    },
    {
      "type": "image_picker",
      "id": "dog_illustration",
      "label": "Dog illustration image"
    },
    {
      "type": "range",
      "id": "dog_illustration_width",
      "label": "Illustration width",
      "min": 100,
      "max": 360,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "How To Feed"
    },
    {
      "type": "textarea",
      "id": "eyebrow_icon_left",
      "label": "Eyebrow left icon (SVG or character)",
      "default": "✦",
      "info": "Type a text character (e.g. ✦ ★ ✿) or paste SVG code. Note: emoji (🐾 etc.) have fixed colors set by the OS and cannot be recolored — use text characters if you want the icon color setting to apply."
    },
    {
      "type": "textarea",
      "id": "eyebrow_icon_right",
      "label": "Eyebrow right icon (SVG or character)",
      "default": "✦",
      "info": "Type a text character (e.g. ✦ ★ ✿) or paste SVG code. Emoji colors are fixed by the OS and cannot be changed via the color setting."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "フィーディングガイド"
    },
    {
      "type": "header",
      "content": "Check / Dosage Section"
    },
    {
      "type": "text",
      "id": "check_badge",
      "label": "Badge label",
      "default": "Check"
    },
    {
      "type": "text",
      "id": "check_heading",
      "label": "Heading",
      "default": "与える量の目安"
    },
    {
      "type": "textarea",
      "id": "check_desc",
      "label": "Description",
      "default": "体重・犬種・活動量に応じて右側の記載内容を目安に調整してください。"
    },
    {
      "type": "header",
      "content": "Food Amount Simulator"
    },
    {
      "type": "checkbox",
      "id": "show_simulator",
      "label": "Show simulator",
      "default": true
    },
    {
      "type": "text",
      "id": "sim_badge",
      "label": "Badge label",
      "default": "Simulation"
    },
    {
      "type": "text",
      "id": "sim_heading",
      "label": "Heading",
      "default": "生食用 食事量シミュレーター"
    },
    {
      "type": "textarea",
      "id": "sim_desc",
      "label": "Description",
      "default": "体重・ライフステージに応じた適切な食事量をシミュレーターで簡単に算出できます。食事量の目安としてご活用ください。"
    },
    {
      "type": "text",
      "id": "sim_weight_label",
      "label": "Weight field label",
      "default": "愛犬の体重"
    },
    {
      "type": "text",
      "id": "sim_stage_label",
      "label": "Life stage field label",
      "default": "愛犬のライフステージ"
    },
    {
      "type": "text",
      "id": "sim_button_label",
      "label": "Calculate button text",
      "default": "ご飯の量を確認する"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#82C9D5"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#FAF6EE"
    },
    {
      "type": "color",
      "id": "cell_bg_color",
      "label": "Dosage cell background",
      "default": "#F0EBE0"
    },
    {
      "type": "color",
      "id": "step_badge_bg_color",
      "label": "Step badge background",
      "default": "#87CEDC"
    },
    {
      "type": "color",
      "id": "step_badge_text_color",
      "label": "Step badge text",
      "default": "#2C5A64"
    },
    {
      "type": "color",
      "id": "dark_badge_bg_color",
      "label": "Check / Simulation badge background",
      "default": "#3D2B1F"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text color",
      "default": "#2C2420"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#6B5A4E"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow text color",
      "default": "#5A4232"
    },
    {
      "type": "color",
      "id": "eyebrow_icon_color",
      "label": "Eyebrow icon color",
      "default": "#D4924A"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Simulator button color",
      "default": "#D4924A"
    }
  ],
  "blocks": [
    {
      "type": "step_card",
      "name": "Step card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image (circular)"
        },
        {
          "type": "text",
          "id": "step_label",
          "label": "Step badge label",
          "default": "ステップ1"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Step heading",
          "default": "保存方法"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Step description",
          "default": "商品が届いたら\nすぐに冷凍庫で保存してください。"
        }
      ]
    },
    {
      "type": "dosage_row",
      "name": "Dosage row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Dog type / life stage",
          "default": "子犬・活発な成犬"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Recommended amount",
          "default": "体重の3〜5%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to feed",
      "blocks": [
        {
          "type": "step_card",
          "settings": {
            "step_label": "ステップ1",
            "heading": "保存方法",
            "body": "商品が届いたら\nすぐに冷凍庫で保存してください。"
          }
        },
        {
          "type": "step_card",
          "settings": {
            "step_label": "ステップ2",
            "heading": "解凍方法",
            "body": "食べる前日の夜に冷蔵庫へ移して\n解凍してください。"
          }
        },
        {
          "type": "step_card",
          "settings": {
            "step_label": "ステップ3",
            "heading": "与え方",
            "body": "加熱せずに\nそのまま与えてください。"
          }
        },
        {
          "type": "dosage_row",
          "settings": {
            "label": "子犬・活発な成犬",
            "value": "体重の3〜5%"
          }
        },
        {
          "type": "dosage_row",
          "settings": {
            "label": "成犬・妊娠中・シニア犬",
            "value": "体重の2〜4%"
          }
        },
        {
          "type": "dosage_row",
          "settings": {
            "label": "妊娠後期・授乳中",
            "value": "体重の3〜6%"
          }
        }
      ]
    }
  ]
}
{% endschema %}
