        },
        {
          "type": "image_picker",
          "id": "dog_image",
          "label": "Custom Dog Image (overrides built-in SVG)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aboutus Commitment",
      "blocks": [
        {
          "type": "commitment_item",
          "settings": {
            "badge_label": "Commitment 01",
