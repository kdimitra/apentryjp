    },
    {
      "type": "image_picker",
      "id": "eyebrow_icon_right",
      "label": "Eyebrow right paw icon (SVG/PNG)",
      "info": "Upload a custom SVG or PNG. Leave blank to use the built-in default paw."
    },
    {
      "type": "text",
