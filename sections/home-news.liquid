
{%- comment -%}
  Home News Section
  Cream background · Left: star + "News" + ニュース heading + "View more" pill + dog illustration
  Right: vertical list of white rounded cards — thumbnail left, title + date right, arrow far right
{%- endcomment -%}

{%- liquid
  assign source_blog  = blogs[section.settings.blog]
  assign posts_limit  = section.settings.posts_to_show
  assign has_articles = false
  if source_blog != blank and source_blog.articles_count > 0
    assign has_articles = true
  endif
-%}

{{ 'section-home-news.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.image_ratio
    when 'square'
      assign thumb_ratio = '1 / 1'
    when 'landscape'
      assign thumb_ratio = '4 / 3'
    when 'portrait'
      assign thumb_ratio = '3 / 4'
    when 'wide'
      assign thumb_ratio = '16 / 9'
    else
      assign thumb_ratio = '1 / 1'
  endcase
-%}

<section
  class="section-home-news"
  id="home-news-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    --hn-thumb-w: {{ section.settings.image_size }}px;
    --hn-thumb-ratio: {{ thumb_ratio }};
  "
>
  <div class="hn-container">
    <div class="hn-inner">

      {%- comment -%}━━━━━━━━ LEFT: Label column ━━━━━━━━{%- endcomment -%}
      <div class="hn-label-col">

        {%- comment -%} ⭐ News eyebrow {%- endcomment -%}
        <p class="hn-eyebrow">
          <span class="hn-eyebrow__star" aria-hidden="true">✦</span>
          {{- section.settings.eyebrow | default: 'News' -}}
        </p>

        {%- comment -%} ニュース heading {%- endcomment -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hn-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- comment -%} View more pill button {%- endcomment -%}
        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="hn-viewall">
            {{- section.settings.cta_label -}}
            <span aria-hidden="true"> ›</span>
          </a>
        {%- endif -%}

        {%- comment -%} Optional dog / decoration image {%- endcomment -%}
        {%- if section.settings.decoration_image != blank -%}
          <div class="hn-decoration">
            {{- section.settings.decoration_image
              | image_url: width: 280
              | image_tag:
                loading: 'lazy',
                widths: '140, 200, 280',
                sizes: '140px',
                alt: ''
            -}}
          </div>
        {%- endif -%}

      </div>

      {%- comment -%}━━━━━━━━ RIGHT: White card list ━━━━━━━━{%- endcomment -%}
      <ul class="hn-list" role="list">

        {%- if has_articles -%}
          {%- for article in source_blog.articles limit: posts_limit -%}
            <li class="hn-card">
              <a href="{{ article.url }}" class="hn-card__link">

                {%- comment -%} Thumbnail {%- endcomment -%}
                {%- if article.image != blank -%}
                  <div class="hn-card__thumb-wrap">
                    {{- article.image
                      | image_url: width: 240
                      | image_tag:
                        loading: 'lazy',
                        widths: '120, 180, 240',
                        sizes: '100px',
                        class: 'hn-card__thumb',
                        alt: article.image.alt | default: article.title | escape
                    -}}
                  </div>
                {%- else -%}
                  <div class="hn-card__thumb-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}

                {%- comment -%} Title + Date {%- endcomment -%}
                <div class="hn-card__text">
                  <h3 class="hn-card__title">{{ article.title | escape }}</h3>
                  <p class="hn-card__date">
                    Date : {{ article.published_at | date: '%Y.%m.%d' }}
                  </p>
                </div>

                {%- comment -%} Arrow circle {%- endcomment -%}
                <div class="hn-card__arrow" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                </div>

              </a>
            </li>
          {%- endfor -%}

        {%- else -%}

          {%- comment -%} Editor placeholders {%- endcomment -%}
          {%- assign ph_titles = 'ゴールデンウィーク休業のお知らせ（2026年）,年末年始休業のお知らせ（2025年）,新商品のご案内：春のフレッシュフード' | split: ',' -%}
          {%- assign ph_dates  = '2026.04.07,2025.12.01,2025.11.15' | split: ',' -%}

          {%- for i in (1..posts_limit) -%}
            {%- assign idx = forloop.index0 -%}
            <li class="hn-card">
              <div class="hn-card__link">

                <div class="hn-card__thumb-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>

                <div class="hn-card__text">
                  <h3 class="hn-card__title">{{ ph_titles[idx] }}</h3>
                  <p class="hn-card__date">Date : {{ ph_dates[idx] }}</p>
                </div>

                <div class="hn-card__arrow" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                </div>

              </div>
            </li>
          {%- endfor -%}

        {%- endif -%}

      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home news",
  "class": "home-news-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "News"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "ニュース"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "decoration_image",
      "label": "Decoration image (e.g. dog illustration)"
    },
    {
      "type": "header",
      "content": "Blog source"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Number of articles",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Image size (desktop)"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Thumbnail width (px)",
      "min": 80,
      "max": 280,
      "step": 8,
      "unit": "px",
      "default": 192
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Thumbnail aspect ratio",
      "options": [
        { "value": "square",    "label": "Square (1:1) — 192×192" },
        { "value": "landscape", "label": "Landscape (4:3)" },
        { "value": "portrait",  "label": "Portrait (3:4)" },
        { "value": "wide",      "label": "Wide (16:9)" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F0EBD8"
    }
  ],
  "presets": [
    {
      "name": "Home news"
    }
  ]
}
{% endschema %}
