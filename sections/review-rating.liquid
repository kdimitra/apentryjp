          "default": "続きを読む"
        },
        {
          "type": "url",
          "id": "read_more_url",
          "label": "Read more link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review rating",
      "blocks": [
        {
          "type": "review_card",
          "settings": {
            "star_rating": 5,
            "date_text": "6ヶ月前",
            "title": "うさぎたちが大好きです！",
            "body": "APを2年間食べ続けてきましたが、この新しいプロテインが発売された時はすごく興奮しました。うちの犬たちは食事の時間になると、",
