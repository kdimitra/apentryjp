
{%- comment -%}
  Review Rating Section
  Layout: cream bg · left col (eyebrow + heading + overall score + rating bars + write-review CTA)
          right col (horizontally scrollable review cards)
  Aggregate rating + count pulled from product metafields (reviews.rating / reviews.rating_count).
  Individual review cards are added as blocks in the Shopify editor.
{%- endcomment -%}

{{ 'section-review-rating.css' | asset_url | stylesheet_tag }}

{%- comment -%} Resolve which product to pull metafields from {%- endcomment -%}
{%- if section.settings.product != blank -%}
  {%- assign rr_product = all_products[section.settings.product] -%}
{%- elsif product != blank -%}
  {%- assign rr_product = product -%}
{%- endif -%}

{%- comment -%} Pull aggregate data from product metafields {%- endcomment -%}
{%- assign meta_rating = rr_product.metafields.reviews.rating -%}
{%- assign meta_count  = rr_product.metafields.reviews.rating_count -%}

{%- if meta_rating != blank -%}
  {%- assign overall_rating  = meta_rating | round: 1 -%}
  {%- assign rating_rounded  = meta_rating | round -%}
{%- else -%}
  {%- assign overall_rating  = 5 -%}
  {%- assign rating_rounded  = 5 -%}
{%- endif -%}

{%- if meta_count != blank -%}
  {%- assign total_count = meta_count -%}
{%- else -%}
  {%- assign total_count = 0 -%}
{%- endif -%}

{%- comment -%} Compute bar widths from per-star counts {%- endcomment -%}
{%- assign bar_total = section.settings.count_5 | plus: section.settings.count_4 | plus: section.settings.count_3 | plus: section.settings.count_2 | plus: section.settings.count_1 -%}

{%- if bar_total > 0 -%}
  {%- assign bar_5 = section.settings.count_5 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_4 = section.settings.count_4 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_3 = section.settings.count_3 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_2 = section.settings.count_2 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_1 = section.settings.count_1 | times: 100 | divided_by: bar_total -%}
{%- else -%}
  {%- assign bar_5 = 0 -%}
  {%- assign bar_4 = 0 -%}
  {%- assign bar_3 = 0 -%}
  {%- assign bar_2 = 0 -%}
  {%- assign bar_1 = 0 -%}
{%- endif -%}

<section
  class="section-rr"
  id="{% if section.settings.section_id != blank %}{{ section.settings.section_id | handleize }}{% else %}review-rating-{{ section.id }}{% endif %}"
  style="
    background-color:        {{ section.settings.bg_color }};
    padding-block-start:     {{ section.settings.padding_top }}px;
    padding-block-end:       {{ section.settings.padding_bottom }}px;
    --rr-cards-per-view:     {{ section.settings.cards_per_view }};
    --rr-eyebrow-icon-color: {{ section.settings.eyebrow_icon_color }};
    --rr-eyebrow-text-color: {{ section.settings.eyebrow_text_color }};
    --rr-heading-color:      {{ section.settings.heading_color }};
    --rr-score-color:        {{ section.settings.score_color }};
    --rr-count-color:        {{ section.settings.count_color }};
    --rr-star-color:         {{ section.settings.star_color }};
    --rr-star-empty-color:   {{ section.settings.star_empty_color }};
    --rr-bar-fill:           {{ section.settings.bar_fill_color }};
    --rr-bar-empty:          {{ section.settings.bar_empty_color }};
    --rr-btn-bg:             {{ section.settings.btn_bg_color }};
    --rr-btn-text:           {{ section.settings.btn_text_color }};
    --rr-card-bg:            {{ section.settings.card_bg_color }};
    --rr-card-title-color:   {{ section.settings.card_title_color }};
    --rr-card-body-color:    {{ section.settings.card_body_color }};
    --rr-card-date-color:    {{ section.settings.card_date_color }};
    --rr-card-link-color:    {{ section.settings.card_link_color }};
  "
>
  <div class="rr-container">

    {%- comment -%}━━━━━━━━ LEFT ━━━━━━━━{%- endcomment -%}
    <div class="rr-left">

      {%- if section.settings.eyebrow != blank -%}
        <p class="rr-eyebrow">
          <span class="rr-eyebrow__icon" aria-hidden="true">{{ section.settings.eyebrow_icon }}</span>
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="rr-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- comment -%} Overall rating — from product metafield {%- endcomment -%}
      <div class="rr-overall">
        <span class="rr-overall__score">{{ overall_rating }}</span>
        <div class="rr-overall__right">
          <div class="rr-overall__stars" aria-label="5点満点中{{ overall_rating }}点">
            {%- for i in (1..5) -%}
              <svg class="rr-star{% if i <= rating_rounded %} rr-star--filled{% endif %}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 1.2l2.47 5.01 5.53.8-4 3.9.94 5.49L10 13.77l-4.94 2.6.94-5.49-4-3.9 5.53-.8z"/>
              </svg>
            {%- endfor -%}
          </div>
          {%- if total_count > 0 -%}
            <span class="rr-overall__count">{{ total_count }}{{ section.settings.review_count_suffix }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Rating breakdown bars {%- endcomment -%}
      <div class="rr-bars" aria-label="評価の内訳">
        {%- assign bar_rows = '5,4,3,2,1' | split: ',' -%}
        {%- for row in bar_rows -%}
          {%- if row == '5' -%}
            {%- assign bar_pct = bar_5 -%}
            {%- assign bar_count = section.settings.count_5 -%}
          {%- elsif row == '4' -%}
            {%- assign bar_pct = bar_4 -%}
            {%- assign bar_count = section.settings.count_4 -%}
          {%- elsif row == '3' -%}
            {%- assign bar_pct = bar_3 -%}
            {%- assign bar_count = section.settings.count_3 -%}
          {%- elsif row == '2' -%}
            {%- assign bar_pct = bar_2 -%}
            {%- assign bar_count = section.settings.count_2 -%}
          {%- else -%}
            {%- assign bar_pct = bar_1 -%}
            {%- assign bar_count = section.settings.count_1 -%}
          {%- endif -%}
          <div class="rr-bar-row">
            <span class="rr-bar-row__label">
              {{ row }}
              <svg class="rr-star rr-star--filled rr-star--sm" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 1.2l2.47 5.01 5.53.8-4 3.9.94 5.49L10 13.77l-4.94 2.6.94-5.49-4-3.9 5.53-.8z"/>
              </svg>
            </span>
            <div class="rr-bar-row__track" role="progressbar" aria-valuenow="{{ bar_pct }}" aria-valuemin="0" aria-valuemax="100">
              <div class="rr-bar-row__fill" style="width: {{ bar_pct }}%;"></div>
            </div>
            <span class="rr-bar-row__count">{{ bar_count }}</span>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="rr-write-btn">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}

    </div>

    {%- comment -%}━━━━━━━━ RIGHT — horizontal scroll carousel ━━━━━━━━{%- endcomment -%}
    <div class="rr-right">
      <div class="rr-cards" role="list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'review_card' -%}
              {%- assign card_rating = block.settings.star_rating | round -%}
              <article class="rr-card" role="listitem" {{ block.shopify_attributes }}>
                <div class="rr-card__header">
                  <div class="rr-card__stars" aria-label="{{ block.settings.star_rating }}点">
                    {%- for i in (1..5) -%}
                      <svg class="rr-star{% if i <= card_rating %} rr-star--filled{% endif %} rr-star--sm" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 1.2l2.47 5.01 5.53.8-4 3.9.94 5.49L10 13.77l-4.94 2.6.94-5.49-4-3.9 5.53-.8z"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.date_text != blank -%}
                    <time class="rr-card__date">{{ block.settings.date_text }}</time>
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="rr-card__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <p class="rr-card__body">{{ block.settings.body }}</p>
                {%- endif -%}
                {%- if block.settings.read_more_url != blank and block.settings.read_more_label != blank -%}
                  <a href="{{ block.settings.read_more_url }}" class="rr-card__link">{{ block.settings.read_more_label }}</a>
                {%- elsif block.settings.read_more_label != blank -%}
                  <span class="rr-card__link">{{ block.settings.read_more_label }}</span>
                {%- endif -%}
              </article>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Editor placeholder cards {%- endcomment -%}
          {%- for i in (1..3) -%}
            <article class="rr-card rr-card--placeholder" role="listitem">
              <div class="rr-card__header">
                <div class="rr-card__stars">
                  {%- for j in (1..5) -%}
                    <svg class="rr-star rr-star--filled rr-star--sm" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M10 1.2l2.47 5.01 5.53.8-4 3.9.94 5.49L10 13.77l-4.94 2.6.94-5.49-4-3.9 5.53-.8z"/>
                    </svg>
                  {%- endfor -%}
                </div>
                <time class="rr-card__date">6ヶ月前</time>
              </div>
              <h3 class="rr-card__title">うさぎたちが大好きです！</h3>
              <p class="rr-card__body">APを2年間食べ続けてきましたが、この新しいプロテインが発売された時はすごく興奮しました。うちの犬たちは食事の時間になると、</p>
              <span class="rr-card__link">続きを読む</span>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- comment -%} Scroll indicator dots — built by JS {%- endcomment -%}
      <div class="rr-dots" aria-hidden="true"></div>
    </div>

  </div>
</section>

<script src="{{ 'section-review-rating.js' | asset_url }}" defer></script>

