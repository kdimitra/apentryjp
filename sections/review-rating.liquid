      "label": "4★ count",
      "default": 0
    },
    {
      "type": "number",
      "id": "count_3",
      "label": "3★ count",
      "default": 0
    },
    {
      "type": "number",
      "id": "count_2",
      "label": "2★ count",
      "default": 0
    },
    {
      "type": "number",
      "id": "count_1",
      "label": "1★ count",
      "default": 0
    },
    {
      "type": "header",
      "content": "Write Review Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "レビューを書く"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
