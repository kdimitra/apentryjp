      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "info": "How many Okendo review cards are visible before scrolling on desktop."
    },
    {
      "type": "header",
      "content": "Rating Breakdown Bars"
    },
    {
      "type": "paragraph",
