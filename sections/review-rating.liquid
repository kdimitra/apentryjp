
{%- comment -%}
  Review Rating Section — Okendo integration
  Layout: cream bg · left col (heading + aggregate score + bars + write-review CTA)
          right col (Okendo reviews widget — horizontal scroll)
  Aggregate rating pulled from product.metafields.reviews.rating (populated by Okendo).
  Individual reviews rendered by Okendo's widget script via data-oke-reviews-widget.
  Requires: Okendo Reviews app installed on the store.
{%- endcomment -%}

{{ 'section-review-rating.css' | asset_url | stylesheet_tag }}

{%- comment -%} Resolve product for metafield + widget context {%- endcomment -%}
{%- if section.settings.product != blank -%}
  {%- assign rr_product = all_products[section.settings.product] -%}
{%- elsif product != blank -%}
  {%- assign rr_product = product -%}
{%- endif -%}

{%- comment -%}
  Pull aggregate data the same way the theme's review.liquid block does.
  Okendo writes to reviews.rating (type: rating) and reviews.rating_count.
{%- endcomment -%}
{%- assign meta_rating       = rr_product.metafields.reviews.rating.value.rating -%}
{%- assign meta_scale_max    = rr_product.metafields.reviews.rating.value.scale_max | default: 5 -%}
{%- assign meta_count        = rr_product.metafields.reviews.rating_count -%}

{%- if meta_rating != blank -%}
  {%- assign overall_rating  = meta_rating | round: 1 -%}
  {%- assign rating_rounded  = meta_rating | round -%}
{%- else -%}
  {%- assign overall_rating  = 5.0 -%}
  {%- assign rating_rounded  = 5 -%}
{%- endif -%}

{%- if meta_count != blank -%}
  {%- assign total_count = meta_count -%}
{%- else -%}
  {%- assign total_count = 0 -%}
{%- endif -%}

{%- comment -%} Bar widths from per-star counts {%- endcomment -%}
{%- assign bar_total = section.settings.count_5 | plus: section.settings.count_4 | plus: section.settings.count_3 | plus: section.settings.count_2 | plus: section.settings.count_1 -%}
{%- if bar_total > 0 -%}
  {%- assign bar_5 = section.settings.count_5 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_4 = section.settings.count_4 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_3 = section.settings.count_3 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_2 = section.settings.count_2 | times: 100 | divided_by: bar_total -%}
  {%- assign bar_1 = section.settings.count_1 | times: 100 | divided_by: bar_total -%}
{%- else -%}
  {%- assign bar_5 = 0 -%}
  {%- assign bar_4 = 0 -%}
  {%- assign bar_3 = 0 -%}
  {%- assign bar_2 = 0 -%}
  {%- assign bar_1 = 0 -%}
{%- endif -%}

<section
  class="section-rr"
  id="{% if section.settings.section_id != blank %}{{ section.settings.section_id | handleize }}{% else %}review-rating-{{ section.id }}{% endif %}"
  style="
    background-color:        {{ section.settings.bg_color }};
    padding-block-start:     {{ section.settings.padding_top }}px;
    padding-block-end:       {{ section.settings.padding_bottom }}px;
    --rr-cards-per-view:     {{ section.settings.cards_per_view }};
    --rr-eyebrow-icon-color: {{ section.settings.eyebrow_icon_color }};
    --rr-eyebrow-text-color: {{ section.settings.eyebrow_text_color }};
    --rr-heading-color:      {{ section.settings.heading_color }};
    --rr-score-color:        {{ section.settings.score_color }};
    --rr-count-color:        {{ section.settings.count_color }};
    --rr-star-color:         {{ section.settings.star_color }};
    --rr-star-empty-color:   {{ section.settings.star_empty_color }};
    --rr-bar-fill:           {{ section.settings.bar_fill_color }};
    --rr-bar-empty:          {{ section.settings.bar_empty_color }};
    --rr-btn-bg:             {{ section.settings.btn_bg_color }};
    --rr-btn-text:           {{ section.settings.btn_text_color }};
    --rr-card-bg:            {{ section.settings.card_bg_color }};
    --rr-card-title-color:   {{ section.settings.card_title_color }};
    --rr-card-body-color:    {{ section.settings.card_body_color }};
    --rr-card-date-color:    {{ section.settings.card_date_color }};
    --rr-card-link-color:    {{ section.settings.card_link_color }};
  "
>
  <div class="rr-container">

    {%- comment -%}━━━━━━━━ LEFT ━━━━━━━━{%- endcomment -%}
    <div class="rr-left">

      {%- if section.settings.eyebrow != blank -%}
        <p class="rr-eyebrow">
          <span class="rr-eyebrow__icon" aria-hidden="true">{{ section.settings.eyebrow_icon }}</span>
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="rr-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- comment -%} Overall score — from Okendo metafields {%- endcomment -%}
      <div class="rr-overall">
        <span class="rr-overall__score">{{ overall_rating }}</span>
        <div class="rr-overall__right">
          <div class="rr-overall__stars" aria-label="{{ meta_scale_max }}点満点中{{ overall_rating }}点">
            {%- for i in (1..5) -%}
              <svg class="rr-star{% if i <= rating_rounded %} rr-star--filled{% endif %}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 1.2l2.47 5.01 5.53.8-4 3.9.94 5.49L10 13.77l-4.94 2.6.94-5.49-4-3.9 5.53-.8z"/>
              </svg>
            {%- endfor -%}
          </div>
          {%- if total_count > 0 -%}
            <span class="rr-overall__count">{{ total_count }}{{ section.settings.review_count_suffix }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Breakdown bars {%- endcomment -%}
      <div class="rr-bars" aria-label="評価の内訳">
        {%- assign bar_rows = '5,4,3,2,1' | split: ',' -%}
        {%- for row in bar_rows -%}
          {%- if row == '5' -%}
            {%- assign bar_pct = bar_5 -%}{%- assign bar_count = section.settings.count_5 -%}
          {%- elsif row == '4' -%}
            {%- assign bar_pct = bar_4 -%}{%- assign bar_count = section.settings.count_4 -%}
          {%- elsif row == '3' -%}
            {%- assign bar_pct = bar_3 -%}{%- assign bar_count = section.settings.count_3 -%}
          {%- elsif row == '2' -%}
            {%- assign bar_pct = bar_2 -%}{%- assign bar_count = section.settings.count_2 -%}
          {%- else -%}
            {%- assign bar_pct = bar_1 -%}{%- assign bar_count = section.settings.count_1 -%}
          {%- endif -%}
          <div class="rr-bar-row">
            <span class="rr-bar-row__label">
              {{ row }}
              <svg class="rr-star rr-star--filled rr-star--sm" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 1.2l2.47 5.01 5.53.8-4 3.9.94 5.49L10 13.77l-4.94 2.6.94-5.49-4-3.9 5.53-.8z"/>
              </svg>
            </span>
            <div class="rr-bar-row__track" role="progressbar" aria-valuenow="{{ bar_pct }}" aria-valuemin="0" aria-valuemax="100">
              <div class="rr-bar-row__fill" style="width: {{ bar_pct }}%;"></div>
            </div>
            <span class="rr-bar-row__count">{{ bar_count }}</span>
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%}
        Write review button.
        Priority:
          1. Custom URL entered in section settings
          2. Okendo's write-review anchor (#oke-write-review) — their JS intercepts
             this and opens the review submission form automatically
          3. Plain # fallback when no product is set
      {%- endcomment -%}
      {%- if section.settings.btn_label != blank -%}
        {%- if section.settings.btn_url != blank -%}
          {%- assign write_review_href = section.settings.btn_url -%}
        {%- elsif rr_product != blank -%}
          {%- assign write_review_href = '#oke-write-review' -%}
        {%- else -%}
          {%- assign write_review_href = '#' -%}
        {%- endif -%}
        <a
          href="{{ write_review_href }}"
          class="rr-write-btn"
          {% if rr_product != blank and section.settings.btn_url == blank %}
            data-oke-reviews-write-review
            data-oke-reviews-product-id="{{ rr_product.id }}"
          {% endif %}
        >
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}

    </div>

    {%- comment -%}━━━━━━━━ RIGHT — Okendo reviews widget ━━━━━━━━{%- endcomment -%}
    <div class="rr-right">

      {%- if rr_product != blank -%}

        {%- comment -%}
          Okendo widget embed.
          When Okendo is installed, their app embed script will populate this div
          with live review cards. The data-oke-reviews-product-id attribute tells
          their script which product's reviews to load.
          CSS in section-review-rating.css overrides Okendo's default layout to
          produce a horizontal scroll carousel matching the section design.
        {%- endcomment -%}
        {%- comment -%}
          Okendo reviews widget embed (v2 data-attribute API).
          Okendo's app embed script (enabled via Theme Customizer → App embeds)
          detects this element and populates it with real review cards.
          Our CSS forces their list to a horizontal scroll carousel.
          Ref: https://help.okendo.io/en/articles/embedding-reviews
        {%- endcomment -%}
        <div
          id="oke-reviews-widget"
          class="rr-okendo-wrapper"
          data-oke-widget="reviews"
          data-oke-reviews-widget
          data-oke-reviews-product-id="{{ rr_product.id }}"
          data-oke-reviews-product-handle="{{ rr_product.handle }}"
        ></div>

      {%- else -%}

        {%- comment -%} Editor placeholder — shown when no product is selected {%- endcomment -%}
        <div class="rr-placeholder">
          <p class="rr-placeholder__text">
            Okendo レビューを表示するには、上の「Product」設定で商品を選択してください。<br>
            <em>Select a product in the section settings to display Okendo reviews here.</em>
          </p>
        </div>

      {%- endif -%}

    </div>

  </div>
</section>

<script src="{{ 'section-review-rating.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Review rating",
  "class": "review-rating-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section ID"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For tab navigation targeting. No spaces or # (e.g. review-section)."
    },
    {
      "type": "header",
      "content": "Product (Okendo data source)"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Overall rating and review count are pulled from this product's Okendo metafields. Individual reviews are fetched and rendered by the Okendo app widget. Leave blank to auto-detect on product pages."
    },
    {
      "type": "text",
      "id": "review_count_suffix",
