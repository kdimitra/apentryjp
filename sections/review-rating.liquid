      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Colors — Section"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#EDE8D6"
    },
    {
      "type": "header",
      "content": "Colors — Left Column"
    },
    {
      "type": "color",
      "id": "eyebrow_icon_color",
      "label": "Eyebrow icon color",
      "default": "#87CEDC"
    },
    {
      "type": "color",
      "id": "eyebrow_text_color",
      "label": "Eyebrow text color",
      "default": "#87CEDC"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2C1A0E"
    },
    {
      "type": "color",
      "id": "score_color",
      "label": "Overall score number color",
      "default": "#2C1A0E"
    },
    {
      "type": "color",
      "id": "count_color",
      "label": "Review count text color",
      "default": "#6B6860"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Filled star color",
      "default": "#E8B84B"
    },
    {
      "type": "color",
      "id": "star_empty_color",
      "label": "Empty star color",
      "default": "#D8D2C8"
    },
    {
      "type": "color",
      "id": "bar_fill_color",
      "label": "Rating bar filled color",
      "default": "#3D2B1F"
    },
    {
      "type": "color",
      "id": "bar_empty_color",
      "label": "Rating bar empty color",
      "default": "#D8D2C8"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background",
      "default": "#F5C430"
    },
    {
      "type": "color",
      "id": "btn_text_color",
